---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="Mensagem Enviada | Augusto Imóveis">
  <Header />
  <main class="success-container">
    <div class="success-card">
      <div class="icon-circle">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>
      </div>
      <h1>Recebemos sua mensagem!</h1>
      <p>Obrigado pelo contato. Nossa equipe analisará sua solicitação e retornará em breve pelo WhatsApp ou e-mail.</p>
      <a href="/" class="back-home">Voltar para o Início</a>
    </div>
  </main>
</Layout>

<style>
  .success-container { height: 80vh; display: flex; align-items: center; justify-content: center; padding: 20px; }
  .success-card { background: white; padding: 60px; border-radius: 32px; text-align: center; max-width: 500px; box-shadow: 0 20px 40px rgba(0,0,0,0.05); }
  .icon-circle { width: 80px; height: 80px; background: #10b981; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 30px; }
  h1 { color: #0f172a; font-size: 2rem; margin-bottom: 15px; font-weight: 800; }
  p { color: #64748b; line-height: 1.6; margin-bottom: 30px; }
  .back-home { display: inline-block; background: #0f172a; color: white; padding: 16px 32px; border-radius: 14px; text-decoration: none; font-weight: 700; transition: 0.3s; }
  .back-home:hover { transform: translateY(-2px); background: #2563eb; }
</style>