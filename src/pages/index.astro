---
// 1. Imports
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import ImovelCard from '../components/ImovelCard.astro'
import HeroSplit from '../components/HeroSplit.astro'
import { sanityClient } from 'sanity:client'
import { allPropertiesQuery } from '../lib/queries'
import { urlFor } from '../lib/image'


const properties = await sanityClient.fetch(allPropertiesQuery)
const featuredProperties = properties.filter(p => p.featured === true);
const normalProperties = properties.filter(p => p.featured !== true);
---

<Layout title="Augusto Narloch | Negócios Imobiliários">
  <div class="site-texture"></div>
  
  <Header />

  <main class="fade-in">
    <HeroSplit />

    <section class="hero-premium">
      <div class="hero-container">
        <div class="hero-content" style="grid-column: 1 / -1; text-align: center; max-width: 900px; margin: 0 auto;">
          <h1>Onde a sua história <br/> <span class="text-serif">ganha um novo endereço.</span></h1>
          
          <p class="hero-description" style="margin: 20px auto 0;">
            Não somos apenas uma lista de imóveis. Somos a ponte entre o seu momento atual e o espaço que você sempre planejou conquistar em Araucária e região.
          </p>
        </div>
      </div>
    </section>

    {featuredProperties.length > 0 && (
      <section class="section-container property-section">
        <div class="section-header-refined">
          <div class="title-group">
            <span class="label">Coleção</span>
            <h2>Destaques Selecionados</h2>
          </div>
          <div class="line"></div>
        </div>
        <div class="grid">
          {featuredProperties.map((property) => (
            <ImovelCard
              imovel={property}
              imageUrl={property.mainImage ? urlFor(property.mainImage).width(800).url() : '/fallback-img.jpg'}
            />
          ))}
        </div>
      </section>
    )}

    <section class="section-container property-section">
      <div class="section-header-refined">
        <div class="title-group">
          <span class="label">Portfólio</span>
          <h2>Adicionados Recentemente</h2>
        </div>
        <div class="line"></div>
      </div>
      <div class="grid">
        {normalProperties.map((property) => (
          <ImovelCard
            imovel={property}
            imageUrl={property.mainImage ? urlFor(property.mainImage).width(800).url() : '/fallback-img.jpg'}
          />
        ))}
      </div>
    </section>
  </main>

  <a href="https://wa.me/5541995683915" class="whatsapp-premium-minimal" target="_blank">
    <div class="btn-content">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
      <span>Falar no WhatsApp</span>
    </div>
    <div class="btn-shine"></div>
  </a>
</Layout>

<style>
  /* 0. RESET GLOBAL DA PÁGINA */
  :global(html), :global(body) {
    margin: 0 !important;
    padding: 0 !important;
    background-color: #b2bfd0 !important;
    overflow-x: hidden;
  }

  .site-texture {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    pointer-events: none; z-index: 9999; opacity: 0.04;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
  }

  :root {
    --bg-solid-gray: #b2bfd0; 
    --accent-blue: #3b82f6;
    --text-main: #0f172a;
  }

  main { 
    background-color: var(--bg-solid-gray); 
    min-height: 100vh;
    padding-top: 20px;
  }

  .hero-premium {
    position: relative;
    padding: 100px 24px; 
    width: 100vw;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    background-image: 
      linear-gradient(to bottom, rgba(15, 23, 42, 0.9) 0%, rgba(15, 23, 42, 0.4) 100%),
      url('/hero-bg.png'); 
    background-size: cover;
    background-position: center;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  }

  .hero-container { 
    max-width: 1300px; 
    margin: 0 auto; 
    display: block;
  }

  h1 {
    font-size: clamp(2.8rem, 5vw, 4.2rem);
    line-height: 1.1; 
    font-weight: 900;
    color: #ffffff;
    letter-spacing: -1.5px;
    text-shadow: 0 4px 4px rgba(0, 0, 0, 0.6), 0 12px 16px rgba(0, 0, 0, 0.4);
  }

  .text-serif { font-family: serif; font-style: italic; color: #60a5fa; }

  .hero-description {
    font-size: 1.25rem; 
    color: #f8fafc;
    text-shadow: 0 4px 6px rgba(0, 0, 0, 0.6);
  }

  .section-container { max-width: 1300px; margin: 0 auto; padding: 60px 24px; }
  .section-header-refined { display: flex; align-items: flex-end; gap: 30px; margin-bottom: 40px; }
  .title-group .label { font-size: 11px; text-transform: uppercase; font-weight: 800; color: var(--accent-blue); letter-spacing: 2px; display: block; margin-bottom: 8px; }
  .title-group h2 { font-size: 2rem; font-weight: 800; color: var(--text-main); margin: 0; }
  .section-header-refined .line { height: 1px; flex-grow: 1; background: linear-gradient(to right, rgba(0,0,0,0.1), transparent); margin-bottom: 12px; }
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 40px; }

  /* WHATSAPP PREMIUM */
  .whatsapp-premium-minimal {
    position: fixed; bottom: 60px; right: 40px;
    background: #25d366; color: #ffffff;
    padding: 14px 28px; border-radius: 100px;
    text-decoration: none; font-weight: 700; font-size: 14px;
    overflow: hidden; transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
    box-shadow: 0 10px 30px rgba(37, 211, 102, 0.3);
    z-index: 1000;
  }

  .whatsapp-premium-minimal .btn-content { display: flex; align-items: center; gap: 12px; position: relative; z-index: 2; }
  .whatsapp-premium-minimal .btn-shine {
    position: absolute; top: 0; left: -100%; width: 100%; height: 100%;
    background: linear-gradient(120deg, transparent, rgba(255, 255, 255, 0.2), transparent);
    transition: all 0.6s ease; z-index: 1;
  }
  .whatsapp-premium-minimal:hover { transform: translateY(-5px) scale(1.03); background: #128c7e; }
  .whatsapp-premium-minimal:hover .btn-shine { left: 100%; }

  .fade-in { animation: fadeIn 0.8s ease-out; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(15px); } to { opacity: 1; } }

  @media (max-width: 768px) {
    .hero-premium { padding: 60px 20px; }
  }
</style>