---
// src/pages/contato.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout 
  title="Fale Conosco | Augusto Narloch Imóveis"
  description="Entre em contato com Augusto Narloch Imóveis. Atendimento especializado em Araucária e região."
>
  <Header />

  <main class="contact-container">
    <div class="breadcrumb-nav">
      <a href="/">Início</a> <span class="divider">/</span> <span class="current">Fale Conosco</span>
    </div>

    <div class="contact-header">
      <h1>Estamos à sua disposição</h1>
      <p>Seja para tirar uma dúvida rápida, agendar uma visita ou solicitar uma avaliação do seu imóvel, nossa equipe está pronta para oferecer um atendimento exclusivo.</p>
    </div>

    <div class="contact-grid">
      
      <div class="info-column">
        
        <a href="https://wa.me/5541995683915" target="_blank" class="info-card whatsapp-card">
          <div class="icon-box">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
          </div>
          <div class="info-texts">
            <h3>WhatsApp</h3>
            <p>Atendimento rápido e direto</p>
            <span class="highlight">(41) 99568-3915</span>
          </div>
        </a>

        <div class="info-card">
          <div class="icon-box dark-icon">
            <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><path d="m22 6-10 7L2 6"/></svg>
          </div>
          <div class="info-texts">
            <h3>E-mail</h3>
            <p>Para envio de documentos e propostas</p>
            <span>contato@augustonarloch.com.br</span>
          </div>
        </div>

        <div class="info-card">
          <div class="icon-box dark-icon">
            <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          </div>
          <div class="info-texts">
            <h3>Horário de Atendimento</h3>
            <p>Segunda a Sexta: 09h às 18h</p>
            <span>Sábados: Plantão de Vendas</span>
          </div>
        </div>

        <div class="info-card">
          <div class="icon-box dark-icon">
            <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div class="info-texts">
            <h3>Região de Atuação</h3>
            <p>Foco de atendimento e captação</p>
            <span>Araucária, PR e Região Metropolitana</span>
          </div>
        </div>

      </div>

      <div class="form-column">
        <div class="form-card">
          <h2>Envie uma Mensagem</h2>
          <p>Prefere e-mail? Preencha os dados abaixo e retornaremos em breve.</p>
          
          <form action="https://api.web3forms.com/submit" method="POST" class="contact-form">
            
            <input type="hidden" name="access_key" value="da67d966-5d7d-414d-a758-a2e9104472cf">
            
            <input type="hidden" name="subject" value="Novo Lead: Contato pelo Site">

            <input type="hidden" name="redirect" value="https://augusto-imoveis-site.vercel.app/sucesso">

            <input type="checkbox" name="botcheck" class="hidden" style="display: none;">

            <div class="input-group">
              <label for="nome">Nome Completo</label>
              <input type="text" id="nome" name="nome" placeholder="Como prefere ser chamado?" required>
            </div>

            <div class="input-row">
              <div class="input-group">
                <label for="telefone">Telefone / WhatsApp</label>
                <input type="tel" id="telefone" name="telefone" placeholder="(41) 90000-0000" required>
              </div>
              <div class="input-group">
                <label for="email">E-mail</label>
                <input type="email" id="email" name="email" placeholder="seu@email.com" required>
              </div>
            </div>

            <div class="input-group">
              <label for="assunto">Qual é o seu objetivo?</label>
              <select id="assunto" name="assunto_interesse">
                <option value="comprar">Quero Comprar um Imóvel</option>
                <option value="vender">Quero Vender/Avaliar meu Imóvel</option>
                <option value="alugar">Quero Alugar um Imóvel</option>
                <option value="assessoria">Preciso de Assessoria Jurídica/Contratos</option>
                <option value="outros">Outros Assuntos</option>
              </select>
            </div>

            <div class="input-group">
              <label for="mensagem">Mensagem</label>
              <textarea id="mensagem" name="mensagem" rows="4" placeholder="Detalhe o que você procura ou as características do seu imóvel..." required></textarea>
            </div>

            <button type="submit" class="submit-btn">
              Enviar Mensagem
              <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </button>
          </form>
        </div>
      </div>

    </div>
  </main>
</Layout>

<style>
  :global(html), :global(body) {
    margin: 0 !important; padding: 0 !important;
    background-color: #b2bfd0;
    font-family: 'Inter', system-ui, sans-serif;
  }

  .contact-container {
    max-width: 1250px;
    margin: 0 auto;
    padding: 120px 20px 100px;
  }

  .breadcrumb-nav { 
    display: flex; align-items: center; gap: 8px;
    font-size: 13px; color: #64748b; font-weight: 600; margin-bottom: 40px; 
  }
  .breadcrumb-nav a { color: #2563eb; text-decoration: none; }
  .breadcrumb-nav .divider { color: #cbd5e1; }
  .breadcrumb-nav .current { color: #0f172a; }

  .contact-header {
    max-width: 700px;
    margin-bottom: 60px;
  }

  .contact-header h1 {
    font-size: 3rem;
    color: #0f172a;
    font-weight: 800;
    margin: 0 0 15px 0;
    letter-spacing: -0.02em;
  }

  .contact-header p {
    font-size: 1.15rem;
    color: #475569;
    line-height: 1.6;
    margin: 0;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 40px;
    align-items: start;
  }

  /* COLUNA DE INFORMAÇÕES */
  .info-column {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .info-card {
    background: #ffffff;
    padding: 24px;
    border-radius: 20px;
    display: flex;
    align-items: center;
    gap: 20px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.03);
    border: 1px solid rgba(255,255,255,0.5);
    transition: 0.3s;
    text-decoration: none;
  }

  .info-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 35px rgba(0,0,0,0.06);
  }

  .whatsapp-card {
    background: linear-gradient(135deg, #10b981 0%, #059669 100%);
    color: white;
    border: none;
  }

  .icon-box {
    width: 50px;
    height: 50px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .whatsapp-card .icon-box { background: rgba(255,255,255,0.2); color: white; }
  .dark-icon { background: #f8fafc; color: #2563eb; }

  .info-texts { display: flex; flex-direction: column; gap: 4px; }
  
  .info-texts h3 { margin: 0; font-size: 1rem; color: #0f172a; font-weight: 700; }
  .whatsapp-card .info-texts h3 { color: white; }
  
  .info-texts p { margin: 0; font-size: 0.85rem; color: #64748b; font-weight: 500; }
  .whatsapp-card .info-texts p { color: rgba(255,255,255,0.8); }

  .info-texts span { font-size: 1.1rem; font-weight: 800; color: #334155; margin-top: 2px;}
  .whatsapp-card .info-texts span { color: white; }


  /* COLUNA DO FORMULÁRIO */
  .form-card {
    background: #ffffff;
    padding: 50px;
    border-radius: 32px;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.05);
  }

  .form-card h2 { margin: 0 0 10px 0; font-size: 1.8rem; color: #0f172a; font-weight: 800;}
  .form-card > p { margin: 0 0 30px 0; color: #64748b; font-size: 1.05rem; }

  .contact-form { display: flex; flex-direction: column; gap: 20px; }

  .input-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }

  .input-group { display: flex; flex-direction: column; gap: 8px; }

  .input-group label { font-size: 0.9rem; font-weight: 700; color: #334155; }

  .contact-form input, .contact-form select, .contact-form textarea {
    width: 100%;
    padding: 16px;
    border-radius: 12px;
    border: 1px solid #e2e8f0;
    background: #f8fafc;
    font-family: inherit;
    font-size: 1rem;
    color: #0f172a;
    transition: 0.3s;
    box-sizing: border-box;
  }

  .contact-form input:focus, .contact-form select:focus, .contact-form textarea:focus {
    outline: none;
    border-color: #2563eb;
    background: #ffffff;
    box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1);
  }

  .submit-btn {
    margin-top: 10px;
    background: #0f172a;
    color: white;
    border: none;
    padding: 18px;
    border-radius: 14px;
    font-size: 1.1rem;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    transition: 0.3s;
  }

  .submit-btn:hover {
    background: #2563eb;
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(37, 99, 235, 0.2);
  }

  /* RESPONSIVO */
  @media (max-width: 1024px) {
    .contact-grid { grid-template-columns: 1fr; }
    .info-column { display: grid; grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 768px) {
    .contact-container { padding-top: 100px; }
    .contact-header h1 { font-size: 2.2rem; }
    .info-column { grid-template-columns: 1fr; }
    .input-row { grid-template-columns: 1fr; }
    .form-card { padding: 30px 20px; border-radius: 24px; }
  }
</style>