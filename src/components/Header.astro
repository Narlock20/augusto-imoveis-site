---
const { pathname } = Astro.url;
const isActive = (path) => path === '/' ? pathname === '/' : pathname.startsWith(path);

// Link do WhatsApp com a mensagem personalizada
const whatsappLink = "https://wa.me/5541995683915?text=Olá! Gostaria de informações sobre como anunciar meu imóvel para venda ou locação no site.";
---

<header class="header">
  <div class="header-container">
  <a href="/" class="logo-wrapper">
    <img src="/logo_marca.png" alt="Augusto Narloch Imóveis" class="site-logo" />

    </a>

    <nav class="nav-menu">
      <a href="/" class={isActive('/') ? 'active' : ''}>
        <span class="nav-text">Início</span>
        <span class="nav-dot"></span>
      </a>
      <a href="/compre" class={isActive('/compre') ? 'active' : ''}>
        <span class="nav-text">Compre</span>
        <span class="nav-dot"></span>
      </a>
      <a href="/alugue" class={isActive('/alugue') ? 'active' : ''}>
        <span class="nav-text">Alugue</span>
        <span class="nav-dot"></span>
      </a>
      <a href="/servicos" class={isActive('/servicos') ? 'active' : ''}>
        <span class="nav-text">Serviços</span>
        <span class="nav-dot"></span>
      </a>
    </nav>

    <div class="header-actions">
      <div class="location-chip">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <span>Araucária, PR</span>
      </div>
      
      <a href={whatsappLink} class="btn-announce-premium" target="_blank">
        <div class="btn-content">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg>
          <span>Anunciar Imóvel</span>
        </div>
        <div class="btn-shine"></div>
      </a>
    </div>
  </div>
</header>

<style>
  .header {
    background: #e6e6e6;
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid rgba(15, 23, 42, 0.06);
    padding: 16px 0;
    position: sticky;
    top: 0;
    z-index: 1000;
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.03);
  }

  .header-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  /* LOGO */
/* Estilo da nova logo em imagem */
  .site-logo {
    height: 90px; /* AUMENTEI AQUI: de 45px para 75px */
    width: auto; 
    object-fit: contain;
    transition: transform 0.3s ease;
  }

  .logo-wrapper:hover .site-logo {
    transform: scale(1.05);
  }

  /* Responsivo para celulares */
  @media (max-width: 768px) {
    .site-logo {
      height: 75px; /* AUMENTEI AQUI TAMBÉM: para ficar visível no mobile */
    }
  }


  /* NAVEGAÇÃO PREMIUM ESTÁVEL (Sem vibração) */
  .nav-menu { 
    display: flex; 
    gap: 24px; 
  }
  
  .nav-menu a {
    text-decoration: none; 
    color: #64748b; 
    font-weight: 600; 
    font-size: 14px;
    position: relative; 
    /* Aumentamos o padding para criar uma área de clique mais "sólida" e ancorar o mouse */
    padding: 8px 0; 
    
    /* A transição agora altera apenas a cor, mantendo o texto totalmente imóvel no eixo Y */
    transition: color 0.3s ease; 
  }

  .nav-menu a:hover, .nav-menu a.active { 
    color: #0f172a; 
  }

  .nav-dot {
    position: absolute; 
    bottom: -2px; 
    left: 50%; 
    transform: translateX(-50%) scale(0);
    width: 5px; 
    height: 5px; 
    background: #2563eb; 
    border-radius: 50%;
    
    /* Transição fluída e contínua, sem o efeito elástico que gerava vibração */
    transition: transform 0.3s ease-out, box-shadow 0.3s ease-out;
  }

  /* O ponto cresce de forma contínua e ganha um brilho sutil */
  .nav-menu a:hover .nav-dot, .nav-menu a.active .nav-dot { 
    transform: translateX(-50%) scale(1); 
    box-shadow: 0 0 8px rgba(37, 99, 235, 0.4);
  }

  /* AÇÕES */
  .header-actions { display: flex; align-items: center; gap: 24px; }
  .location-chip {
    display: flex; align-items: center; gap: 8px;
    padding: 8px 14px; background: #f1f5f9; border-radius: 50px;
    color: #475569; font-size: 12px; font-weight: 700;
  }

  /* BOTÃO PREMIUM: ANUNCIAR IMÓVEL */
  .btn-announce-premium {
    position: relative;
    background: #0f172a;
    color: white;
    text-decoration: none;
    padding: 12px 24px;
    border-radius: 14px;
    font-size: 14px;
    font-weight: 700;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
    box-shadow: 0 10px 20px rgba(15, 23, 42, 0.1);
  }

  .btn-content {
    display: flex;
    align-items: center;
    gap: 10px;
    position: relative;
    z-index: 2;
  }

  /* Brilho que passa pelo botão (Textura) */
  .btn-shine {
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      120deg,
      transparent,
      rgba(255, 255, 255, 0.1),
      transparent
    );
    transition: all 0.6s;
    z-index: 1;
  }

  /* EFEITOS DE MOVIMENTO E SOMBRA */
  .btn-announce-premium:hover {
    transform: translateY(-3px) scale(1.02);
    background: #1e293b;
    box-shadow: 0 15px 30px rgba(15, 23, 42, 0.2);
  }

  .btn-announce-premium:hover .btn-shine {
    left: 100%;
  }

  .btn-announce-premium:active {
    transform: translateY(-1px);
  }

  /* RESPONSIVO */
  @media (max-width: 1024px) {
    .location-chip { display: none; }
    .header-container { padding: 0 20px; }
  }

  @media (max-width: 768px) {
    .nav-menu { display: none; }
  }
</style>