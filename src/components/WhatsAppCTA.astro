---
// src/components/WhatsAppCTA.astro
const phone = "5541995683915"; // Substitua pelo seu número
const message = encodeURIComponent("Olá! Vi um imóvel no site e gostaria de mais informações.");
const whatsappUrl = `https://wa.me/${phone}?text=${message}`;
---

<a 
  href={whatsappUrl}
  target="_blank"
  rel="noopener noreferrer"
  class="fixed bottom-6 right-6 z-50 bg-[#25D366] text-white p-4 rounded-full shadow-2xl hover:scale-110 transition-transform flex items-center justify-center"
  aria-label="Contato via WhatsApp"
>
  <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
    <path d="M.057 24l1.687-6.163c-1.041-1.804-1.591-3.849-1.591-5.946 0-6.556 5.332-11.888 11.887-11.888 3.179 0 6.167 1.239 8.413 3.483 2.246 2.247 3.485 5.234 3.485 8.413 0 6.558-5.333 11.89-11.888 11.89-2.001 0-3.963-.505-5.703-1.465l-6.29 1.654zm6.206-3.791l.345.205c1.1.654 2.378.999 3.693.999 3.86 0 7.001-3.141 7.001-7.001 0-1.868-.728-3.623-2.05-4.945s-3.078-2.05-4.946-2.05c-3.861 0-7.001 3.141-7.001 7.001 0 1.341.385 2.651 1.114 3.785l.225.352-.98 3.581 3.674-.966z"/>
  </svg>
</a>