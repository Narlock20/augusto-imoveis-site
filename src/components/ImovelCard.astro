---
import { getCloudinaryUrl } from '../lib/cloudinary';
import { urlFor } from '../lib/image';

// Recebemos a prop 'exibirComo' para saber se estamos na página de Compre ou Alugue
const { imovel, exibirComo } = Astro.props;

// Lógica do Cloudinary
const rawUrl = urlFor(imovel.mainImage).url();
const optimizedThumb = getCloudinaryUrl(rawUrl, 800, 500);

// 1. Lógica de Status (Suporta String única ou Array)
const statusRaw = imovel.status;
const statusArray = Array.isArray(statusRaw) 
  ? statusRaw.map(s => s.toLowerCase().trim()) 
  : [statusRaw?.toLowerCase().trim() || ''];

const isVenda = statusArray.includes('venda');
const isAluguel = statusArray.includes('aluguel') || statusArray.includes('locação') || statusArray.includes('aluga');

// 2. Variável de Título
const tipoFisico = imovel.propertyType ? imovel.propertyType : 'Imóvel';

// 3. Lógica de Preço Blindada (Evita o erro de toLocaleString)
let precoExibicao = 0;
let labelExibicao = "Investimento";

if (exibirComo === 'aluguel') {
  precoExibicao = imovel.priceAluguel || imovel.price || 0;
  labelExibicao = "Valor mensal";
} else if (exibirComo === 'venda') {
  precoExibicao = imovel.priceVenda || imovel.price || 0;
  labelExibicao = "Investimento";
} else {
  // Na Home: Prioriza venda, se não tiver, mostra aluguel
  precoExibicao = imovel.priceVenda || imovel.priceAluguel || imovel.price || 0;
  labelExibicao = imovel.priceVenda ? "Investimento" : (imovel.priceAluguel ? "Valor mensal" : "Investimento");
}

// Verifica se deve mostrar o "/mês"
const mostrarMensal = exibirComo === 'aluguel' || (statusArray.includes('aluguel') && !imovel.priceVenda);
---

<a href={`/imovel/${imovel.slug}`} 
   class="card property-item" 
   data-status={statusArray.join(',')}
   data-preco={precoExibicao}
   data-cidade={imovel.city}
   data-bairro={imovel.neighborhood}
   data-bedrooms={imovel.bedrooms}
>
      
  <div class="image-container">
    <img src={optimizedThumb} alt={imovel.title} loading="lazy" />

    <div class="badges-wrapper">
      {isVenda && <span class="badge badge-venda">A VENDA</span>}
      {isAluguel && <span class="badge badge-aluguel">ALUGUEL</span>}
      
      {(!isVenda && !isAluguel && imovel.status) && (
        <span class="badge badge-default">
          {Array.isArray(imovel.status) ? imovel.status[0].toUpperCase() : imovel.status.toUpperCase()}
        </span>
      )}
    </div>

    <div class="card-overlay">
      <span class="city-tag">{imovel.city}</span>
    </div>
  </div>

  <div class="card-body">
    <header>
      <span class="neighborhood">{tipoFisico} em {imovel.neighborhood}</span>
      <h3>{imovel.title}</h3>
    </header>
    
    <div class="specs-grid">
      <div class="spec-item">
        <span class="label">Área</span>
        <span class="value">{imovel.area}m²</span>
      </div>
      <div class="spec-item">
        <span class="label">Quartos</span>
        <span class="value">{imovel.bedrooms} {imovel.suites > 0 && `(${imovel.suites} suíte)`}</span>
      </div>
      <div class="spec-item">
        <span class="label">Banheiros</span>
        <span class="value">{imovel.bathrooms || '0'}</span>
      </div>
    </div>

    {imovel.amenities && imovel.amenities.length > 0 && (
      <div class="amenities-list">
        {imovel.amenities.slice(0, 3).map((item) => (
          <span class="amenity-tag">{item}</span>
        ))}
        {imovel.amenities.length > 3 && <span class="more">+{imovel.amenities.length - 3}</span>}
      </div>
    )}

    <div class="card-footer">
      <div class="price-box">
        <span class="price-label">{labelExibicao}</span>
        <span class="price-value">
          {precoExibicao > 0 ? (
            `R$ ${precoExibicao.toLocaleString('pt-BR')}`
          ) : (
            "Sob consulta"
          )}
          {mostrarMensal && precoExibicao > 0 && <span style="font-size: 0.9rem; font-weight: 600; color: #64748b;">/mês</span>}
        </span>
      </div>
      
      <div class="explore-indicator">
        <span>Explorar</span>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </div>
    </div>
  </div>
</a>


<style>
  .badge {
    position: relative; 
    z-index: 20;
    padding: 5px 14px;
    border-radius: 50px;
    font-size: 9px;
    font-weight: 800;
    color: #ffffff;
    letter-spacing: 1.5px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    width: fit-content;
    box-shadow: 
      inset 0 1px 0 rgba(255, 255, 255, 0.4),
      0 4px 8px rgba(0, 0, 0, 0.15);
  }

  .badges-wrapper {
    position: absolute;
    top: 16px;
    left: 16px;
    z-index: 20;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .badge-venda { background: linear-gradient(135deg, #10b981 0%, #059669 100%); }
  .badge-aluguel { background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%); }
  .badge-default { background: linear-gradient(135deg, #64748b 0%, #334155 100%); }

  .card {
    background: #d2d9e1;
    border-radius: 20px;
    border: 1px solid #edf2f7;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  .card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.06);
    border-color: #2563eb;
  }

  .image-container { position: relative; height: 240px; overflow: hidden; }
  img { width: 100%; height: 100%; object-fit: cover; transition: 0.6s; }
  .card:hover img { transform: scale(1.05); }

  .image-container::before {
    content: "";
    position: absolute;
    top: 0; left: 0; width: 100%; height: 40%;
    background: linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, transparent 100%);
    z-index: 10;
    pointer-events: none;
  }

  .card-overlay { position: absolute; bottom: 12px; left: 12px; z-index: 20;}
  .city-tag { background: rgba(15, 23, 42, 0.9); color: white; padding: 4px 10px; border-radius: 6px; font-size: 11px; font-weight: 700; text-transform: uppercase; }

  .card-body { padding: 24px; flex-grow: 1; display: flex; flex-direction: column; }
  .neighborhood { color: #2563eb; font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; }
  h3 { font-size: 1.25rem; margin: 8px 0 20px; color: #0f172a; line-height: 1.3; font-weight: 700; }

  .specs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    padding: 16px 0;
    border-top: 1px solid #f1f5f9;
    border-bottom: 1px solid #f1f5f9;
  }

  .spec-item { display: flex; flex-direction: column; gap: 4px; }
  .spec-item .label { font-size: 10px; color: #64748b; text-transform: uppercase; font-weight: 600; }
  .spec-item .value { font-size: 13px; color: #1e293b; font-weight: 700; }

  .amenities-list { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 16px; }
  .amenity-tag { background: #f8fafc; color: #475569; padding: 4px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; border: 1px solid #e2e8f0; }
  .more { font-size: 11px; color: #94a3b8; font-weight: 600; padding: 4px; }

  .card-footer { 
    margin-top: auto; 
    padding-top: 24px; 
    display: flex; 
    justify-content: space-between; 
    align-items: flex-end; 
  }
  
  .price-label { display: block; font-size: 10px; color: #64748b; font-weight: 600; text-transform: uppercase; margin-bottom: 4px; }
  .price-value { font-size: 1.4rem; font-weight: 800; color: #0f172a; display: block; }

  /* NOVO INDICADOR VISUAL (Substitui o botão azul) */
  .explore-indicator {
    display: flex;
    align-items: center;
    gap: 6px;
    color: #64748b; /* Cinza discreto por padrão */
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: all 0.3s ease;
  }

  /* Quando o mouse passa por cima do card, a seta fica azul e desliza sutilmente */
  .card:hover .explore-indicator {
    color: #2563eb;
    transform: translateX(4px);
  }
</style>